        document.addEventListener("DOMContentLoaded", function() {
            const expDateElement = document.getElementById("expiration-date");
            const remainingDaysElement = document.getElementById("remaining-days");

            if (expDateElement && remainingDaysElement) {
                // 取得截止日期字串，並將點替換為斜線以便解析 (例：2026.03.25 -> 2026/03/25)
                const expDateStr = expDateElement.textContent.trim().replace(/\./g, '/'); 
                const expDate = new Date(expDateStr);
                const currentDate = new Date();

                // 將時間設為午夜 00:00:00，確保只計算天數差
