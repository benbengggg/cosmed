                currentDate.setHours(0, 0, 0, 0);

                // 計算時間差 (毫秒)，並轉換成天數
                const timeDiff = expDate.getTime() - currentDate.getTime();
                const daysDiff = Math.ceil(timeDiff / (1000 * 3600 * 24));

                // 根據天數更新文字
                if (daysDiff > 0) {
                    remainingDaysElement.textContent = `剩餘${daysDiff}天`;
                } else if (daysDiff === 0) {
                    remainingDaysElement.textContent = "今天到期";
                } else {
                    remainingDaysElement.textContent = "已過期";
                }
            }

            // 隨機產生 18 位數字的訂單編號
            const orderNumberElement = document.getElementById("order-number");
            if (orderNumberElement) {
                let randomDigits = '';
                for (let i = 0; i < 18; i++) {
                    randomDigits += Math.floor(Math.random() * 10);
                }
                orderNumberElement.textContent = 'P' + randomDigits;
            }

            // 條碼動態更新邏輯
            const barcodeInput = document.getElementById('barcode-input');
            const barcodeSvg = document.getElementById('barcode-svg');

            function updateBarcode() {
                if (typeof JsBarcode !== 'undefined' && barcodeInput && barcodeSvg) {
                    const value = barcodeInput.value || ' '; // 避免空值時套件報錯，預設給一個空格
                    JsBarcode("#barcode-svg", value, {
                        format: "CODE128", // 支援多種字元的通用格式
                        width: 2,
                        height: 80,
                        displayValue: false, // 我們已經有輸入框顯示數值，所以條碼自帶的隱藏
                        margin: 0,
                        background: "transparent",
                        lineColor: "#000000"
                    });
                }
            }

            if (barcodeInput) {
                // 取得網址的 GET 參數
                const urlParams = new URLSearchParams(window.location.search);
                const codeParam = urlParams.get('code');
                
                // 如果有 code 參數，就替換掉預設的條碼值
                if (codeParam) {
                    barcodeInput.value = codeParam;
                }

                updateBarcode(); // 初始化畫面時先渲染一次
                barcodeInput.addEventListener('input', updateBarcode); // 監聽輸入框變化
            }
        });
    </script>
</body>
</html>
